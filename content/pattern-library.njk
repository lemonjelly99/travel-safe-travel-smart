{# =====================================================================
   PATTERN LIBRARY – LOCAL STYLES
   Scoped styles for the pattern library page itself.
   These would NOT ship with the design system.
   ===================================================================== #}
<style>
  .pl-section {
    padding-block: var(--space-12);
    border-block-end: 1px solid var(--color-border);
  }
  .pl-section:last-child {
    border-block-end: none;
  }
  .pl-heading {
    font-family: var(--font-family-heading);
    font-size: var(--text-3xl);
    color: var(--color-navy);
    margin-block-end: var(--space-2);
  }
  .pl-subheading {
    font-family: var(--font-family-heading);
    font-size: var(--text-xl);
    color: var(--color-navy);
    margin-block-end: var(--space-4);
    margin-block-start: var(--space-10);
    padding-block-end: var(--space-2);
    border-block-end: 2px solid var(--color-yellow);
    display: inline-block;
  }
  .pl-description {
    font-size: var(--text-md);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-block-end: var(--space-8);
  }
  .pl-specimen {
    padding: var(--space-6);
    border: 1px dashed var(--color-grey-300);
    border-radius: var(--radius-lg);
    margin-block-end: var(--space-6);
    background: var(--color-white);
  }
  .pl-specimen--dark {
    background: var(--color-navy);
    border-color: var(--color-navy-light);
  }
  .pl-specimen--cream {
    background: var(--color-cream);
    border-color: var(--color-cream-dark);
  }
  .pl-code {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    background: var(--color-navy-dark);
    color: var(--color-cream);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-block-end: var(--space-6);
    white-space: pre;
    line-height: 1.6;
  }
  .pl-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-caps);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-block-end: var(--space-3);
  }
  .pl-swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: var(--space-4);
  }
  .pl-swatch {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .pl-swatch__color {
    height: 4.5rem;
  }
  .pl-swatch__meta {
    padding: var(--space-3);
    font-size: var(--text-xs);
    line-height: 1.5;
    background: var(--color-white);
  }
  .pl-swatch__name {
    font-weight: var(--font-weight-semibold);
    color: var(--color-navy);
  }
  .pl-swatch__value {
    color: var(--color-text-muted);
    font-family: var(--font-family-mono);
  }
  .pl-type-sample {
    margin-block-end: var(--space-4);
    padding-block-end: var(--space-4);
    border-block-end: 1px solid var(--color-border);
  }
  .pl-type-meta {
    font-size: var(--text-xs);
    font-family: var(--font-family-mono);
    color: var(--color-text-muted);
    margin-block-start: var(--space-2);
  }
  .pl-spacing-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-block-end: var(--space-3);
  }
  .pl-spacing-bar {
    height: 1.5rem;
    background: var(--color-yellow);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-yellow-dark);
  }
  .pl-spacing-label {
    font-size: var(--text-xs);
    font-family: var(--font-family-mono);
    color: var(--color-text-muted);
    flex-shrink: 0;
    width: 10rem;
  }
  .pl-shadow-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--space-6);
  }
  .pl-shadow-box {
    background: var(--color-white);
    border-radius: var(--radius-md);
    height: 6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-family: var(--font-family-mono);
    color: var(--color-text-muted);
  }
  .pl-radius-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    align-items: end;
  }
  .pl-radius-item {
    text-align: center;
  }
  .pl-radius-box {
    width: 5rem;
    height: 5rem;
    background: var(--color-cream);
    border: 2px solid var(--color-navy);
    margin-block-end: var(--space-2);
  }
  .pl-radius-label {
    font-size: var(--text-xs);
    font-family: var(--font-family-mono);
    color: var(--color-text-muted);
  }
  .pl-toc {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .pl-toc a {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-cream);
    color: var(--color-navy);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    transition: background-color 150ms ease, color 150ms ease;
  }
  .pl-toc a:hover {
    background: var(--color-navy);
    color: var(--color-white);
  }
  .pl-grid-demo > * {
    background: var(--color-cream);
    border: 1px dashed var(--color-grey-300);
    padding: var(--space-4);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }
  .pl-inline-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }
</style>


