<section id="forms" class="pl-section o-container">
  <h2 class="pl-heading">Forms</h2>
  <p class="pl-description">Form elements and the contact form component. Includes validation states, hint text, and grouped options.</p>

  <h3 class="pl-subheading">Form Elements</h3>
  <div class="pl-specimen">
    <div class="c-form">

      <div class="c-form__group">
        <label class="c-form__label c-form__label--required" for="pl-name">Text input (required)</label>
        <input class="c-form__input" type="text" id="pl-name" placeholder="Your full name">
      </div>

      <div class="c-form__group">
        <label class="c-form__label" for="pl-email-hint">Input with hint</label>
        <span class="c-form__hint" id="pl-email-desc">We'll only use this to respond to your enquiry.</span>
        <input class="c-form__input" type="email" id="pl-email-hint" placeholder="you@example.com" aria-describedby="pl-email-desc">
      </div>

      <div class="c-form__group">
        <label class="c-form__label c-form__label--required" for="pl-error-field">Input with error</label>
        <input class="c-form__input c-form__input--error" type="email" id="pl-error-field" value="not-an-email" aria-invalid="true" aria-describedby="pl-error-msg">
        <span class="c-form__error" id="pl-error-msg">Please enter a valid email address.</span>
      </div>

      <div class="c-form__group">
        <label class="c-form__label" for="pl-select">Select dropdown</label>
        <select class="c-form__input c-form__select" id="pl-select">
          <option value="">Choose an option&hellip;</option>
          <option value="school">School engagement</option>
          <option value="safety">Safety concern</option>
          <option value="partnership">Partnership</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="c-form__group">
        <label class="c-form__label" for="pl-textarea">Textarea</label>
        <textarea class="c-form__input" id="pl-textarea" rows="4" placeholder="Describe your enquiry&hellip;"></textarea>
      </div>

      <fieldset class="c-form__fieldset">
        <legend class="c-form__legend">Radio group</legend>
        <div class="c-form__option">
          <input type="radio" id="pl-r1" name="pl-radio" value="a" checked>
          <label for="pl-r1">School or youth engagement</label>
        </div>
        <div class="c-form__option">
          <input type="radio" id="pl-r2" name="pl-radio" value="b">
          <label for="pl-r2">Local safety concern</label>
        </div>
        <div class="c-form__option">
          <input type="radio" id="pl-r3" name="pl-radio" value="c">
          <label for="pl-r3">Partnership opportunity</label>
        </div>
      </fieldset>

      <fieldset class="c-form__fieldset">
        <legend class="c-form__legend">Checkbox group</legend>
        <div class="c-form__option">
          <input type="checkbox" id="pl-c1" name="pl-check" checked>
          <label for="pl-c1">I agree to the privacy policy</label>
        </div>
        <div class="c-form__option">
          <input type="checkbox" id="pl-c2" name="pl-check">
          <label for="pl-c2">Subscribe to updates</label>
        </div>
      </fieldset>

      <div class="c-form__actions">
        {{ button({ label: "Submit form", type: "submit", style: "primary" }) }}
        {{ button({ label: "Cancel", type: "button", style: "ghost" }) }}
      </div>

    </div>
  </div>

  <h3 class="pl-subheading">Form Banners</h3>
  <div class="pl-specimen">
    <div class="c-form__banner c-form__banner--success" role="alert">
      Thank you for your message. We'll be in touch shortly.
    </div>
    <div class="c-form__banner c-form__banner--error" role="alert" style="margin-block-start: var(--space-4)">
      There was a problem sending your message. Please try again.
    </div>
  </div>

  <h3 class="pl-subheading">Full Contact Form</h3>
  <p>The complete contact form partial is included below. In your templates use <code>{%- raw %}{% include "partials/contact-form.njk" %}{% endraw %}</code>.</p>
</section>

