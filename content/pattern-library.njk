      <div class="pl-radius-item">
        <div class="pl-radius-box" style="border-radius: var(--radius-md)"></div>
        <div class="pl-radius-label">--radius-md<br>0.5rem</div>
      </div>
      <div class="pl-radius-item">
        <div class="pl-radius-box" style="border-radius: var(--radius-lg)"></div>
