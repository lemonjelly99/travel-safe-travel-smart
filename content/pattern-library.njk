      <div class="pl-shadow-box" style="box-shadow: var(--shadow-xs)">--shadow-xs</div>
      <div class="pl-shadow-box" style="box-shadow: var(--shadow-sm)">--shadow-sm</div>
      <div class="pl-shadow-box" style="box-shadow: var(--shadow-md)">--shadow-md</div>
      <div class="pl-shadow-box" style="box-shadow: var(--shadow-lg)">--shadow-lg</div>
      <div class="pl-shadow-box" style="box-shadow: var(--shadow-xl)">--shadow-xl</div>
      <div class="pl-shadow-box" style="box-shadow: var(--shadow-focus)">--shadow-focus</div>
    </div>
  </div>
</section>


