<section id="utilities" class="pl-section o-container">
  <h2 class="pl-heading">Utilities</h2>
  <p class="pl-description">Single-purpose override classes with <code>!important</code>. Use sparingly for one-off adjustments. All use the <code>u-</code> namespace prefix.</p>

  <h3 class="pl-subheading">Text</h3>
  <div class="pl-specimen">
    <p class="u-text-center" style="margin-block-end: var(--space-3)"><code>.u-text-center</code> &mdash; This text is centred</p>
    <p class="u-text-right" style="margin-block-end: var(--space-3)"><code>.u-text-right</code> &mdash; This text is right-aligned</p>
    <p class="u-font-bold" style="margin-block-end: var(--space-3)"><code>.u-font-bold</code> &mdash; This text is bold</p>
    <p class="u-color-muted" style="margin-block-end: var(--space-3)"><code>.u-color-muted</code> &mdash; This text is muted</p>
    <p class="u-text-sm" style="margin-block-end: 0"><code>.u-text-sm</code> &mdash; This text is small</p>
  </div>

  <h3 class="pl-subheading">Backgrounds</h3>
  <div class="pl-specimen">
    <div class="pl-inline-row">
      <span class="u-bg-navy u-color-white" style="padding: var(--space-3) var(--space-4); border-radius: var(--radius-md)">.u-bg-navy</span>
      <span class="u-bg-cream" style="padding: var(--space-3) var(--space-4); border-radius: var(--radius-md)">.u-bg-cream</span>
      <span class="u-bg-yellow" style="padding: var(--space-3) var(--space-4); border-radius: var(--radius-md)">.u-bg-yellow</span>
      <span class="u-bg-white" style="padding: var(--space-3) var(--space-4); border-radius: var(--radius-md); border: 1px solid var(--color-border)">.u-bg-white</span>
    </div>
  </div>

  <h3 class="pl-subheading">Spacing</h3>
  <div class="pl-specimen">
    <p>Margin: <code>.u-mt-0</code>, <code>.u-mt-4</code>, <code>.u-mt-8</code>, <code>.u-mt-12</code>, <code>.u-mb-0</code>, <code>.u-mb-4</code>, <code>.u-mb-8</code>, <code>.u-mb-12</code></p>
    <p>Padding: <code>.u-pt-0</code>, <code>.u-pb-0</code>, <code>.u-p-4</code>, <code>.u-p-6</code>, <code>.u-p-8</code></p>
  </div>

  <h3 class="pl-subheading">Display &amp; Visibility</h3>
  <div class="pl-specimen">
    <p><code>.u-hidden</code> &mdash; display: none</p>
    <p><code>.u-hide-mobile</code> &mdash; hidden below 48rem</p>
    <p><code>.u-hide-tablet</code> &mdash; hidden above 48rem</p>
    <p><code>.u-show-desktop</code> &mdash; visible only above 64rem</p>
    <p style="margin-block-end: 0"><code>.u-no-print</code> &mdash; hidden when printing</p>
  </div>

  <h3 class="pl-subheading">Accessible Hide</h3>
  <div class="pl-specimen">
    <p><code>.o-sr-only</code> &mdash; visually hidden but available to screen readers. Part of the Objects layer. Becomes visible on <code>:focus</code>.</p>
  </div>
</section>
