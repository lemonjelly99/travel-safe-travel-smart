{# ==========================================================================
   MACRO: Feature Block
   Renders an icon + title + description + link block.

   Usage:
     {% from "macros/feature.njk" import feature %}

     {{ feature({
       icon:    "🎓",
       title:   "Education & Outreach",
       text:    "We deliver engaging, age-appropriate rail safety sessions...",
       linkUrl: "/what-we-do/#education-and-outreach",
       linkText: "Learn more",
       inverse: false
     }) }}
   ========================================================================== #}

{% macro feature(props) %}
<div class="c-feature{% if props.inverse %} c-feature--inverse{% endif %}">
  {% if props.icon %}
  <div class="c-feature__icon" aria-hidden="true">
    {% if props.iconSvg %}
      {{ props.iconSvg | safe }}
    {% else %}
      {{ props.icon }}
    {% endif %}
  </div>
  {% endif %}

  <h3 class="c-feature__title">{{ props.title }}</h3>

  {% if props.text %}
  <p class="c-feature__text">{{ props.text }}</p>
  {% endif %}

  {% if props.linkUrl %}
  <a class="c-feature__link" href="{{ props.linkUrl }}">
    {{ props.linkText | default("Read more") }}
  </a>
  {% endif %}
</div>
{% endmacro %}
